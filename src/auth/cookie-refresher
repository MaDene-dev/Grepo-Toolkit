const puppeteer = require("puppeteer");
const fs        = require("fs");
const path      = require("path");
const logger    = require("../utils/logger");

const COOKIES_FILE = path.join(__dirname, "../../cookies.json");

async function refreshCookies(config) {
  const username   = process.env.GREPO_EMAIL    || config.account.username;
  const password   = process.env.GREPO_PASSWORD || config.account.password;
  const world      = config.account.world;
  const langPrefix = world.match(/^([a-z]+)/)?.[1] ?? "en";
  const portal     = `https://${langPrefix}-play.grepolis.com`;
  const startUrl   = `https://${langPrefix}0.grepolis.com/start/index`;

  if (!username || !password) throw new Error("GREPO_EMAIL en GREPO_PASSWORD zijn vereist.");

  logger.info("[CookieRefresher] Browser starten...");
  const browser = await puppeteer.launch({
    headless: "new",
    args: ["--no-sandbox", "--disable-setuid-sandbox", "--disable-dev-shm-usage"],
  });

  try {
    const page = await browser.newPage();
    await page.setViewport({ width: 1280, height: 800 });
    await page.setUserAgent("Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36");

    // Onderschep de login-redirect URL (bevat ?login=1&p=...&ts=...)
    let loginRedirectUrl = null;
    page.on("request", request => {
      const url = request.url();
      if (url.includes(`${world}.grepolis.com`) && url.includes("login=1")) {
        loginRedirectUrl = url;
        logger.info(`[CookieRefresher] Login-URL onderschept: ${url}`);
      }
    });
    page.on("response", response => {
      const url = response.url();
      if (url.includes(`${world}.grepolis.com`) && url.includes("login=1")) {
        loginRedirectUrl = url;
      }
    });

    // Stap 1: Inloggen op portaal
    logger.info(`[CookieRefresher] Portaal laden: ${portal}`);
    await page.goto(portal, { waitUntil: "networkidle2", timeout: 30000 });
    await page.waitForSelector("input[type='email'], input[name='login'], input[type='text']", { timeout: 15000 });

    const emailField = await page.$("input[type='email']") ?? await page.$("input[name='login']") ?? await page.$("input[type='text']");
    await emailField.click({ clickCount: 3 });
    await emailField.type(username, { delay: 60 });
    const passField = await page.$("input[type='password']");
    await passField.click();
    await passField.type(password, { delay: 60 });
    await passField.press("Enter");
    await new Promise(r => setTimeout(r, 4000));
    logger.info(`[CookieRefresher] URL na login: ${page.url()}`);

    // Stap 2: Naar startpagina met wereldkeuze
    logger.info(`[CookieRefresher] Startpagina laden: ${startUrl}`);
    await page.goto(startUrl, { waitUntil: "networkidle2", timeout: 30000 });
    await new Promise(r => setTimeout(r, 2000));

    // Stap 3: Vind en klik de "Spelen" knop voor de juiste wereld
    logger.info(`[CookieRefresher] Zoeken naar Spelen-knop voor ${world}...`);

    // Log alle links en knoppen voor diagnose
    const allLinks = await page.evaluate((world) => {
      return Array.from(document.querySelectorAll("a, button, input[type=submit]"))
        .map(el => ({ tag: el.tagName, text: el.textContent?.trim().substring(0, 40), href: el.href || "", onclick: el.getAttribute("onclick") || "" }))
        .filter(el => el.text || el.href.includes("grepolis"));
    }, world);

    logger.info(`[CookieRefresher] Knoppen op pagina:`);
    allLinks.forEach(el => logger.info(`  [${el.tag}] "${el.text}" href="${el.href.substring(0,60)}" onclick="${el.onclick.substring(0,60)}"`));

    // Klik op de knop die naar nl133 verwijst of "Spelen" zegt
    const clicked = await page.evaluate((world) => {
      const all = Array.from(document.querySelectorAll("a, button, input[type=submit]"));

      // Zoek op href die world bevat
      const byHref = all.find(el => el.href?.includes(world + ".grepolis.com"));
      if (byHref) { byHref.click(); return `href: ${byHref.href}`; }

      // Zoek op onclick die world bevat
      const byOnclick = all.find(el => el.getAttribute("onclick")?.includes(world));
      if (byOnclick) { byOnclick.click(); return `onclick: ${byOnclick.getAttribute("onclick")}`; }

      // Zoek "Spelen" knop (NL) of "Play" (EN)
      const byText = all.find(el => ["spelen", "play", "spelen!"].includes(el.textContent?.trim().toLowerCase()));
      if (byText) { byText.click(); return `text: ${byText.textContent?.trim()}`; }

      return null;
    }, world);

    logger.info(`[CookieRefresher] Geklikt: ${clicked ?? "niets gevonden"}`);

    // Stap 4: Wacht op de login-redirect URL
    let waited = 0;
    while (!loginRedirectUrl && waited < 15) {
      await new Promise(r => setTimeout(r, 1000));
      waited++;
    }

    if (loginRedirectUrl) {
      // Navigeer naar de onderschepte URL om sessie-cookies te krijgen
      logger.info(`[CookieRefresher] Navigeren naar login URL...`);
      await page.goto(loginRedirectUrl, { waitUntil: "networkidle2", timeout: 30000 });
      await new Promise(r => setTimeout(r, 4000));
      logger.info(`[CookieRefresher] Eindpagina: ${(await page.content()).length} bytes | ${page.url()}`);
    } else {
      logger.warn(`[CookieRefresher] Login-redirect URL niet onderschept`);
    }

    // Stap 5: Cookies ophalen van alle domeinen
    const cookies = await page.cookies(
      `https://${world}.grepolis.com`,
      portal,
      `https://${langPrefix}0.grepolis.com`
    );

    logger.info(`[CookieRefresher] ${cookies.length} cookies opgehaald`);
    if (cookies.length < 5) throw new Error(`Te weinig cookies (${cookies.length}) — login mislukt`);

    const cookieData = cookies.map(c => ({
      name: c.name, value: c.value, domain: c.domain,
      path: c.path, secure: c.secure, httpOnly: c.httpOnly,
      expirationDate: c.expires > 0 ? c.expires : undefined,
    }));

    fs.writeFileSync(COOKIES_FILE, JSON.stringify(cookieData, null, 2));
    logger.info(`[CookieRefresher] ✓ ${cookieData.length} cookies opgeslagen`);
    return cookieData;

  } finally {
    await browser.close();
  }
}

module.exports = { refreshCookies };
