const puppeteer = require("puppeteer");
const fs        = require("fs");
const path      = require("path");
const logger    = require("../utils/logger");

const COOKIES_FILE = path.join(__dirname, "../../cookies.json");

async function refreshCookies(config) {
  const username = process.env.GREPO_EMAIL    || config.account.username;
  const password = process.env.GREPO_PASSWORD || config.account.password;
  const world    = config.account.world;
  const langPrefix = world.match(/^([a-z]+)/)?.[1] ?? "en";
  const portal   = `https://${langPrefix}-play.grepolis.com`;

  if (!username || !password) {
    throw new Error("GREPO_EMAIL en GREPO_PASSWORD zijn vereist voor automatisch vernieuwen.");
  }

  logger.info("[CookieRefresher] Browser starten...");

  const browser = await puppeteer.launch({
    headless: "new",
    args: ["--no-sandbox", "--disable-setuid-sandbox", "--disable-dev-shm-usage"],
  });

  try {
    const page = await browser.newPage();
    await page.setUserAgent(
      "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
    );

    // Stap 1: Naar portaal
    logger.info(`[CookieRefresher] Portaal laden: ${portal}`);
    await page.goto(portal, { waitUntil: "networkidle2", timeout: 30000 });

    // Stap 2: Login-formulier invullen
    logger.info("[CookieRefresher] Login invullen...");

    // Wacht op het login-veld (SPA laadt asynchroon)
    await page.waitForSelector("input[type='email'], input[name='login'], input[type='text']", { timeout: 10000 });

    // Vul email in
    const emailField = await page.$("input[type='email']") ?? await page.$("input[name='login']") ?? await page.$("input[type='text']");
    await emailField.click({ clickCount: 3 });
    await emailField.type(username, { delay: 50 });

    // Vul wachtwoord in
    const passField = await page.$("input[type='password']");
    await passField.click();
    await passField.type(password, { delay: 50 });

    // Stuur formulier in
    await Promise.all([
      page.waitForNavigation({ waitUntil: "networkidle2", timeout: 30000 }).catch(() => {}),
      passField.press("Enter"),
    ]);

    // Stap 3: Wacht op redirect naar game
    await new Promise(r => setTimeout(r, 3000));

    // Klik op de wereld als er een wereldkeuze is
    const worldLink = await page.$(`a[href*="${world}"]`);
    if (worldLink) {
      logger.info(`[CookieRefresher] Wereld ${world} selecteren...`);
      await Promise.all([
        page.waitForNavigation({ waitUntil: "networkidle2", timeout: 30000 }).catch(() => {}),
        worldLink.click(),
      ]);
      await new Promise(r => setTimeout(r, 3000));
    }

    // Stap 4: Cookies ophalen
    const cookies = await page.cookies();

    if (cookies.length < 3) {
      throw new Error(`Te weinig cookies opgehaald (${cookies.length}) — login mogelijk mislukt.`);
    }

    // Sla op als JSON (Cookie-Editor formaat)
    const cookieData = cookies.map(c => ({
      name:           c.name,
      value:          c.value,
      domain:         c.domain,
      path:           c.path,
      secure:         c.secure,
      httpOnly:       c.httpOnly,
      expirationDate: c.expires > 0 ? c.expires : undefined,
    }));

    fs.writeFileSync(COOKIES_FILE, JSON.stringify(cookieData, null, 2));
    logger.info(`[CookieRefresher] ✓ ${cookies.length} cookies opgeslagen in cookies.json`);

    return cookieData;
  } finally {
    await browser.close();
  }
}

module.exports = { refreshCookies };
